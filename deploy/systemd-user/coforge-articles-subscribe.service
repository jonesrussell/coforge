[Unit]
Description=Coforge NorthCloud Article Subscriber
After=network.target
ConditionPathExists=/home/deployer/coforge/current

[Service]
Type=simple
WorkingDirectory=/home/deployer/coforge/current
ExecStart=/usr/bin/php artisan articles:subscribe
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
